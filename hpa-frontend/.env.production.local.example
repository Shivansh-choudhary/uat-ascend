# Copy to .env.production.local (gitignored) and fill Azure values, then: npm run build
#
# Azure Portal → App registrations → Authentication:
# Platform must be "Single-page application" (SPA) — NOT "Web" (fixes AADSTS9002326).
# Redirect URI: https://sobhaascend.sobhaapps.com
VITE_MSAL_CLIENT_ID=your-azure-application-client-id
VITE_MSAL_TENANT_ID=your-azure-tenant-id
VITE_MSAL_REDIRECT_URI=https://sobhaascend.sobhaapps.com
VITE_API_BASE_URL=https://sobhaascend.sobhaapps.com
